# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is tracked.

# Pulse document parser — https://docs.runpulse.com
# Header: x-api-key
# Sandbox keys: hello@trypulse.ai
PULSE_API_KEY=

# Eval harness — OpenRouter unified gateway (Anthropic + OpenAI via one key)
# https://openrouter.ai/docs
OPENROUTER_API_KEY=

# Optional: direct vendor keys if you want to bypass OpenRouter
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# VOYAGE_API_KEY=
